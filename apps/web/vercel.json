{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/internal/qstash/ops/outbox-dispatch?limit=50",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/internal/qstash/maintenance/reporting?action=backfill&windowDays=35",
      "schedule": "15 1 * * *"
    },
    {
      "path": "/api/internal/qstash/maintenance/reporting?action=reconcile&windowDays=35",
      "schedule": "35 1 * * *"
    },
    {
      "path": "/api/internal/qstash/maintenance/reporting?action=archive-plan&graceDays=14",
      "schedule": "5 2 * * 1"
    }
  ]
}
