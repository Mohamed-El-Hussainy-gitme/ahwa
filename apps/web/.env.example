# Copy to apps/web/.env.local for local development only.
# Do NOT commit apps/web/.env.local.
#
# Canonical production contract:
# - CONTROL_PLANE_SUPABASE_*
# - one or more AHWA_OPERATIONAL_DATABASE__<TOKEN>__* env groups

CONTROL_PLANE_SUPABASE_URL=https://your-control-plane-project.supabase.co
CONTROL_PLANE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_control_plane_key
CONTROL_PLANE_SUPABASE_SECRET_KEY=sb_secret_control_plane_key

AHWA_OPERATIONAL_DATABASE__OPS_MAIN__URL=https://your-ops-main-project.supabase.co
AHWA_OPERATIONAL_DATABASE__OPS_MAIN__PUBLISHABLE_KEY=sb_publishable_ops_main_key
AHWA_OPERATIONAL_DATABASE__OPS_MAIN__SECRET_KEY=sb_secret_ops_main_key

AHWA_SESSION_SECRET=replace-with-a-long-random-secret
AHWA_INSTALL_TOKEN=replace-with-a-bootstrap-token
AHWA_DEVICE_PAIRING_CODE=replace-with-a-device-pairing-code
CRON_SECRET=replace-with-a-long-random-cron-secret
ARCHIVE_APPROVAL_SECRET=replace-with-a-separate-archive-approval-secret
