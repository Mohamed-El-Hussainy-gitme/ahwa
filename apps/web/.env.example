# Copy to apps/web/.env.local for local development only.
# Do NOT commit apps/web/.env.local.
# Prefer modern Supabase keys.
# Legacy anon/service_role keys are still supported as a fallback.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_project_publishable_key
SUPABASE_SECRET_KEY=sb_secret_your_project_secret_key

# Legacy fallback names if you have not migrated yet:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key

AHWA_SESSION_SECRET=replace-with-a-long-random-secret
AHWA_INSTALL_TOKEN=replace-with-a-bootstrap-token
AHWA_DEVICE_PAIRING_CODE=replace-with-a-device-pairing-code
