# Copy to apps/web/.env.local for local development only.
# Do NOT commit apps/web/.env.local.

CONTROL_PLANE_SUPABASE_URL=https://your-control-plane.supabase.co
CONTROL_PLANE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_control_plane_publishable_key
CONTROL_PLANE_SUPABASE_SECRET_KEY=sb_secret_your_control_plane_secret_key

AHWA_DEFAULT_OPERATIONAL_DATABASE_KEY=ops-db-01
AHWA_OPERATIONAL_DATABASE__OPS_DB_01__URL=https://your-ops-db-01.supabase.co
AHWA_OPERATIONAL_DATABASE__OPS_DB_01__PUBLISHABLE_KEY=sb_publishable_your_ops_db_01_publishable_key
AHWA_OPERATIONAL_DATABASE__OPS_DB_01__SECRET_KEY=sb_secret_your_ops_db_01_secret_key

# Optional browser fallback only for local development.
# NEXT_PUBLIC_DEFAULT_OPERATIONAL_SUPABASE_URL=https://your-ops-db-01.supabase.co
# NEXT_PUBLIC_DEFAULT_OPERATIONAL_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_ops_db_01_publishable_key

# Legacy fallback names remain supported internally only.
# NEXT_PUBLIC_SUPABASE_URL=https://legacy-single-db.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=legacy-publishable-key
# SUPABASE_SECRET_KEY=legacy-secret-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=legacy-anon-key
# SUPABASE_SERVICE_ROLE_KEY=legacy-service-role-key

AHWA_SESSION_SECRET=replace-with-a-long-random-secret
AHWA_INSTALL_TOKEN=replace-with-a-bootstrap-token
AHWA_DEVICE_PAIRING_CODE=replace-with-a-device-pairing-code
CRON_SECRET=replace-with-a-long-random-cron-secret
ARCHIVE_APPROVAL_SECRET=replace-with-a-separate-archive-approval-secret
