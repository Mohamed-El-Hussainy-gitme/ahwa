{
  "name": "ahwa-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build:shared && npm run build:web",
    "dev": "node ./scripts/dev-workspace.mjs",
    "typecheck": "npm run typecheck:shared && npm run typecheck:web",
    "dev:web": "npm run dev --workspace @ahwa/web",
    "build:web": "npm run build --workspace @ahwa/web",
    "build:db-baselines": "node ./scripts/build-db-baselines.mjs",
    "lint:web": "npm run lint --workspace @ahwa/web",
    "build:shared": "npm run build --workspace @ahwa/shared",
    "typecheck:web": "npm run typecheck --workspace @ahwa/web",
    "typecheck:shared": "npm run build:shared",
    "check:legacy:web": "node ./scripts/check-no-legacy-usage.mjs ./apps/web/src ./packages/shared/src",
    "verify:phase5-6": "node ./scripts/verify-phase5-6-cleanup.mjs",
    "verify:phase7-8": "node ./scripts/verify-phase7-8-realtime.mjs",
    "verify:phase9": "node ./scripts/verify-phase9-local-runtime.mjs",
    "verify:phase9-explicit-db": "node ./scripts/verify-phase9-explicit-db-propagation.mjs",
    "verify:platform-response-hardening": "node ./scripts/verify-platform-response-hardening.mjs",
    "verify:phase10": "node ./scripts/verify-phase10-regression.mjs",
    "smoke:phase10": "node ./scripts/smoke-phase10-runtime-e2e.mjs",
    "verify:authz": "node ./scripts/check-ops-authz-coverage.mjs",
    "verify:1to1-lock": "node ./scripts/check-final-1to1-lock.mjs",
    "verify:release": "node ./scripts/check-release-readiness.mjs",
    "verify:control-plane-manual-db-selection": "node ./scripts/verify-control-plane-manual-db-selection.mjs",
    "verify:batch4": "node ./scripts/check-batch4-admin-hygiene.mjs",
    "verify:reporting-maintenance": "node ./scripts/verify-reporting-maintenance-release.mjs",
    "verify:reporting-read-path": "node ./scripts/verify-reporting-read-path.mjs",
    "smoke:reporting-maintenance": "node ./scripts/smoke-reporting-maintenance.mjs",
    "verify:archive-hardening": "node ./scripts/verify-archive-hardening-release.mjs",
    "smoke:archive-hardening": "node ./scripts/smoke-archive-hardening.mjs",
    "archive:plan": "node ./scripts/manage-reporting-archive-approval.mjs plan",
    "archive:execute": "node ./scripts/manage-reporting-archive-approval.mjs execute",
    "dispatch:ops-outbox": "node ./scripts/dispatch-ops-outbox.mjs",
    "load:ops:provision": "node ./scripts/load/provision-ops-fixtures.mjs",
    "load:ops": "node ./scripts/load/run-ops-load.mjs",
    "soak:ops": "node ./scripts/load/run-ops-soak.mjs",
    "failure:ops": "node ./scripts/load/run-ops-failure-lab.mjs",
    "report:capacity": "node ./scripts/load/build-capacity-report.mjs",
    "verify:phase30": "node ./scripts/verify-phase30-load-lab.mjs"
  },
  "packageManager": "npm@10.8.2"
}
