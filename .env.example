# Workspace environment reference
#
# Canonical production contract:
# - CONTROL_PLANE_SUPABASE_*
# - one or more AHWA_OPERATIONAL_DATABASE__<TOKEN>__* env groups
#
# Legacy NEXT_PUBLIC/SUPABASE_* names are removed from the supported runtime
# contract. Configure control-plane and explicit operational database bindings only.

CONTROL_PLANE_SUPABASE_URL=https://your-control-plane-project.supabase.co
CONTROL_PLANE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_control_plane_key
CONTROL_PLANE_SUPABASE_SECRET_KEY=sb_secret_control_plane_key

AHWA_OPERATIONAL_DATABASE__OPS_MAIN__URL=https://your-ops-main-project.supabase.co
AHWA_OPERATIONAL_DATABASE__OPS_MAIN__PUBLISHABLE_KEY=sb_publishable_ops_main_key
AHWA_OPERATIONAL_DATABASE__OPS_MAIN__SECRET_KEY=sb_secret_ops_main_key

AHWA_SESSION_SECRET=replace-with-a-long-random-secret
AHWA_INSTALL_TOKEN=replace-with-a-bootstrap-token
AHWA_DEVICE_PAIRING_CODE=replace-with-a-device-pairing-code
CRON_SECRET=replace-with-a-long-random-cron-secret
ARCHIVE_APPROVAL_SECRET=replace-with-a-separate-archive-approval-secret

AHWA_OPS_EVENT_BUS_DRIVER=auto
AHWA_OPS_EVENT_BUS_REDIS_URL=redis://localhost:6379
AHWA_OPS_EVENT_BUS_REDIS_PREFIX=ahwa
AHWA_OPS_EVENT_BUS_REDIS_MAXLEN=20000
AHWA_OPS_OUTBOX_DISPATCH_BATCH_LIMIT=100
AHWA_OPS_OUTBOX_RETRY_AFTER_SECONDS=15
AHWA_OPS_OUTBOX_MAX_ATTEMPTS=20
AHWA_OPS_OUTBOX_INLINE_DISPATCH_ENABLED=false
AHWA_SERVER_OBSERVABILITY_ENABLED=true


# Load / soak / failure lab
AHWA_LOAD_BASE_URL=http://127.0.0.1:3000
AHWA_LOAD_PROFILE_PATH=./scripts/load/profiles/default-ops-mix.json
AHWA_LOAD_FIXTURE_PATH=./tmp/load/ops-fixtures.json
AHWA_LOAD_OUTPUT_PATH=./tmp/load/ops-load-result.json
AHWA_SOAK_SNAPSHOT_OUTPUT_PATH=./tmp/load/ops-soak-snapshots.json
AHWA_FAILURE_OUTPUT_PATH=./tmp/load/ops-failure-result.json
AHWA_CAPACITY_OUTPUT_PATH=./tmp/load/ops-capacity-report.json
AHWA_CAPACITY_HEADROOM_FACTOR=0.7
AHWA_LOAD_SLUG_PREFIX=load
AHWA_LOAD_CAFE_PREFIX=Load Cafe
AHWA_LOAD_OWNER_PREFIX=Load Owner

AHWA_PWA_PUSH_VAPID_SUBJECT=mailto:ops@example.com
AHWA_PWA_PUSH_PUBLIC_KEY=replace-with-vapid-public-key
AHWA_PWA_PUSH_PRIVATE_KEY=replace-with-vapid-private-key
NEXT_PUBLIC_AHWA_PWA_PUSH_PUBLIC_KEY=replace-with-vapid-public-key
