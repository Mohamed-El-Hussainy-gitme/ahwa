{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/internal/maintenance/reporting?action=backfill&windowDays=35",
      "schedule": "15 1 * * *"
    },
    {
      "path": "/api/internal/maintenance/reporting?action=reconcile&windowDays=35",
      "schedule": "35 1 * * *"
    },
    {
      "path": "/api/internal/maintenance/reporting?action=archive-plan&graceDays=14",
      "schedule": "5 2 * * 1"
    }
  ]
}
